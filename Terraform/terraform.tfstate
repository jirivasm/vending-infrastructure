            "max_history": 0,
            "metadata": [
              {
                "app_version": "v2.11.4",
                "chart": "argo-cd",
                "name": "argocd",
                "namespace": "argocd",
                "revision": 1,
                "values": "{\"global\":{\"resources\":{\"limits\":{\"cpu\":\"500m\",\"memory\":\"512Mi\"},\"requests\":{\"cpu\":\"100m\",\"memory\":\"256Mi\"}}},\"redis\":{\"enabled\":true,\"persistence\":{\"enabled\":true,\"size\":\"2Gi\",\"storageClass\":\"longhorn\"}},\"repoServer\":{\"persistence\":{\"accessMode\":\"ReadWriteOnce\",\"enabled\":true,\"size\":\"5Gi\",\"storageClass\":\"longhorn\"},\"resources\":{\"limits\":{\"cpu\":\"1000m\",\"memory\":\"1Gi\"},\"requests\":{\"cpu\":\"250m\",\"memory\":\"512Mi\"}}},\"server\":{\"extraArgs\":[\"--insecure\"],\"ingress\":{\"annotations\":{\"traefik.ingress.kubernetes.io/router.entrypoints\":\"web\",\"traefik.ingress.kubernetes.io/router.middlewares\":\"traefik-forwarded-proto@kubernetescrd\"},\"enabled\":true,\"hosts\":[\"argo.jirivasm.dev\"],\"ingressClassName\":\"traefik\"}}}",
                "version": "7.3.4"
              }
            ],
            "name": "argocd",
            "namespace": "argocd",
            "pass_credentials": false,
            "postrender": [],
            "recreate_pods": false,
            "render_subchart_notes": true,
            "replace": false,
            "repository": "https://argoproj.github.io/argo-helm",
            "repository_ca_file": null,
            "repository_cert_file": null,
            "repository_key_file": null,
            "repository_password": null,
            "repository_username": null,
            "reset_values": false,
            "reuse_values": false,
            "set": [],
            "set_list": [],
            "set_sensitive": [],
            "skip_crds": false,
            "status": "deployed",
            "timeout": 300,
            "values": [
              "repoServer:\r\n  persistence:\r\n    enabled: true\r\n    storageClass: \"longhorn\"  # Updated to use Longhorn\r\n    accessMode: ReadWriteOnce\r\n    size: 5Gi \r\n  resources:\r\n    limits:\r\n      cpu: \"1000m\"      # Allow it to use a full core during manifest generation\r\n      memory: \"1Gi\"     # Bump this to 1Gi to handle Helm/Git tasks\r\n    requests:\r\n      cpu: \"250m\"\r\n      memory: \"512Mi\"\r\nredis:\r\n  enabled: true\r\n  persistence:\r\n    enabled: true\r\n    storageClass: \"longhorn\"  # Updated to use Longhorn\r\n    size: 2Gi\r\n\r\nserver:\r\n  extraArgs:\r\n    - --insecure # Allows Traefik/Cloudflare to handle SSL\r\n  ingress:\r\n    enabled: true\r\n    ingressClassName: traefik  # Switched from Nginx to Traefik\r\n    hosts:\r\n      - argo.jirivasm.dev\r\n    annotations:\r\n      # Traefik specific annotations\r\n      traefik.ingress.kubernetes.io/router.entrypoints: web\r\n      traefik.ingress.kubernetes.io/router.middlewares: \"traefik-forwarded-proto@kubernetescrd\"\r\n      # If using SSL via Traefik/Cloudflare, you might use:\r\n      # traefik.ingress.kubernetes.io/router.tls: \"true\"\r\n\r\n# Resource limits tailored for your mini PC cluster\r\nglobal:\r\n  resources:\r\n    limits:\r\n      cpu: 500m\r\n      memory: 512Mi\r\n    requests:\r\n      cpu: 100m\r\n      memory: 256Mi"
            ],
            "verify": false,
            "version": "7.3.4",
            "wait": true,
            "wait_for_jobs": false
          },
          "sensitive_attributes": [],
          "private": "eyJzY2hlbWFfdmVyc2lvbiI6IjEifQ==",
          "dependencies": [
            "helm_release.longhorn",
            "null_resource.k3s_master",
            "null_resource.k3s_workers"
          ]
        }
      ]
    },
