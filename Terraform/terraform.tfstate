            "lint": false,
            "manifest": null,
            "max_history": 0,
            "metadata": [
              {
                "app_version": "1.21.2",
                "chart": "vault",
                "name": "vault",
                "namespace": "hashicorp",
                "revision": 1,
                "values": "{\"server\":{\"dataStorage\":{\"enabled\":true,\"size\":\"5Gi\",\"storageClass\":\"longhorn\"},\"standalone\":{\"config\":\"ui = true\\nlistener \\\"tcp\\\" {\\n  tls_disable = 1\\n  address     = \\\"[::]:8200\\\"\\n  cluster_address = \\\"[::]:8201\\\"\\n}\\nstorage \\\"file\\\" {\\n  path = \\\"/vault/data\\\"\\n}\\n\",\"enabled\":true},\"ui\":{\"enabled\":true,\"serviceType\":\"ClusterIP\"}}}",
                "version": "0.32.0"
              }
            ],
            "name": "vault",
            "namespace": "hashicorp",
            "pass_credentials": false,
            "postrender": [],
            "recreate_pods": false,
            "render_subchart_notes": true,
            "replace": false,
            "repository": "https://helm.releases.hashicorp.com",
            "repository_ca_file": null,
            "repository_cert_file": null,
            "repository_key_file": null,
            "repository_password": null,
            "repository_username": null,
            "reset_values": false,
            "reuse_values": false,
            "set": [],
            "set_list": [],
            "set_sensitive": [],
            "skip_crds": false,
            "status": "deployed",
            "timeout": 300,
            "values": [
              "server:\r\n  # Use Longhorn for persistent storage\r\n  dataStorage:\r\n    enabled: true\r\n    size: 5Gi\r\n    storageClass: \"longhorn\"\r\n      \r\n  # This is the Helm-level UI setting\r\n  ui:\r\n    enabled: true\r\n    serviceType: ClusterIP\r\n      \r\n  standalone:\r\n    enabled: true\r\n    # This nested 'config' block is strictly for Vault's HCL syntax\r\n    config: |\r\n      ui = true\r\n      listener \"tcp\" {\r\n        tls_disable = 1\r\n        address     = \"[::]:8200\"\r\n        cluster_address = \"[::]:8201\"\r\n      }\r\n      storage \"file\" {\r\n        path = \"/vault/data\"\r\n      }\r\n"
            ],
            "verify": false,
            "version": "0.32.0",
            "wait": true,
            "wait_for_jobs": false
          },
          "sensitive_attributes": [],
          "private": "eyJzY2hlbWFfdmVyc2lvbiI6IjEifQ==",
          "dependencies": [
            "helm_release.longhorn",
            "null_resource.k3s_master",
            "null_resource.k3s_workers"
          ]
        }
      ]
